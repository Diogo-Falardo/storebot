# web/.dockerignore

# Vite / build artifacts

dist/
build/
.output/
.preview/
.cache/
.vite/
.tanstack/ # ← sometimes generated route trees, etc.

# Dependencies (very large in modern React stacks)

node_modules/
npm-debug.log
yarn-error.log
pnpm-lock.yaml

# Environment files

.env
.env.\*
!.env.example
.env.local
.env.development.local
.env.production.local

# Testing & reports

coverage/
vitest/
playwright-report/
test-results/

# Editor / IDE

.vscode/
.idea/
\*.swp
.DS_Store

# Formatting & lint cache

.prettiercache
.eslintcache

# Git

.git
.gitignore

# Docker related (if building only from this folder)

Dockerfile*
docker-compose*

# Misc large/unneeded

public/sitemap.xml # if generated dynamically
\*.log
